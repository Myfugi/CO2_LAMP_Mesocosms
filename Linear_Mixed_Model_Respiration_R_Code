#Linear Mixes Effects Model for CO2 concentration measured with CO2 Sensor Equipped
#mesocosms vs a traditional Gas Chromatograph. 

#Load Necessary Libraries and Packages
library(Rmisc)
library(ggplot2)
library(rstatix)
library(lme4)
library(lmerTest)
library(easystats)
library(tidyverse)
library(glmmTMB)

#Load in the data
RESP<-read.delim(file.choose())

#Check Structure of the data
str(RESP)
head(RESP)
RESP
#Need to set ID, Sensor, Run, Hours, and Method as "Factors" 

RESP<-RESP%>%convert_as_factor(ID,Sensor,Run,Timestep,Method)
RESP$Hours<-RESP$Timestep
#check your work
str(RESP)


#Get Summary Statistics, group by Hours and Method
RESP.summary<-summarySE(RESP,measurevar="Respiration",groupvars=c("Hours","Method"))


#plot the data to visualize
RESP1.plot<-ggplot(RESP.summary,aes(x=Hours,y=Respiration,colour=Method,group=Method))+geom_errorbar(aes(ymin=Respiration-se,ymax=Respiration+se),width=.2)+geom_line()+theme_bw()+geom_point(size=4)
RESP1.plot
#If we look at the GC and sensor overlap, we can see that there's a bit of separation at times 48 and 72, but otherwise not much, so these are probably not different

#but we need to run a mixed model or repeat measure anova to confirm, but as there are data points missing
#from the sensor data, a linear mixed model is the better approach
#We want to look at the effect of sensor on the concentration, to see if there is an effect, and if there is an interaction

RESP.Sens.Summary<-summarySE(RESP, measurevar = "Respiration", groupvars = c("Hours","Sensor"))

#Visualize that data
RESP.sens.plot<-ggplot(RESP.Sens.Summary,aes(x=Hours,y=Respiration,colour=Sensor,group=Sensor))+geom_errorbar(aes(ymin=Respiration-se,ymax=Respiration+se),width=.2)+geom_line()+theme_bw()+geom_point(size=4)
RESP.sens.plot
#It doesn't look like the different sensors are obviously different from one another

RESP.All.Summary<-summarySE(RESP, measurevar = "Respiration", groupvars = c("Sensor","Method"))
RESP.All.plot<-ggplot(RESP.All.Summary,aes(x=Method,y=Respiration,colour=Sensor,group=Sensor))+geom_errorbar(aes(ymin=Respiration-se,ymax=Respiration+se),width=.2)+geom_line()+theme_bw()+geom_point(size=4)
RESP.All.plot

#Looking at respiration, we can see that there doesn't seem to be a difference between respiration calculated from 
#GC vs from sensor, but that there is possibly some differences between the individual sensors. We may not be able to treat
#sensor as a random effect


#Get Summary Statistics, group by Hours and Run
RESP.Run.Summary<-summarySE(RESP, measurevar = "Respiration", groupvars = c("Hours","Run"))

#Visualize that data
RESP.Run.plot<-ggplot(RESP.Run.Summary,aes(x=Hours,y=Respiration,colour=Run,group=Run))+geom_errorbar(aes(ymin=Respiration-se,ymax=Respiration+se),width=.2)+geom_line()+theme_bw()+geom_point(size=4)
RESP.Run.plot
# there's no obvious effect of run on the concentration, so Run can remain being considered a random effect. 

#run a linear mixed model treating sensor as random to try and rule out run as a significant effect: 
RESP$Hours<-RESP$Timestep
RESP.lmer<-lmer(Respiration~Hours*Method*Run + (1|Sensor),data=RESP)
RESP.lmer.anova<-anova(RESP.lmer)
RESP.lmer.anova
#When we check the ANOVA, Nothing is significant, but we're getting P values of 1, so this is probably a bit tooo good
#to be true. Lets try it with Run as a random effect

RESP1.lmer<-lmer(Respiration~Hours*Method*Sensor + (1|Run), data=RESP)
#we get a singular fit, So we've over parameterized

#Check the Assumption of normality
RESP1.qqplot<-qqnorm(resid(RESP1.lmer))
RESP1.qqline<-qqline(resid(RESP1.lmer))
#Imperfect Normality, there are some pretty clear outliers here, however lme models are robust to
#violations of normality, so we're going to go ahead and still run anova 

#run an Anova on the linear mixed model wth a type II Wald test
RESP1.lmer.Anova<-Anova(RESP1.lmer)
RESP1.lmer.Anova

#Timestep and sensor are both significant effects, but method is not, however there is a significant interaction
#effect, so we may need to investigate that further, We're also going to do an anova using a type III ANOVA 
#using Satterthwaite's method

RESP1.lmer.anova<-anova(RESP1.lmer)
RESP1.lmer.anova
#Now we see no significant effects, but p-values are all 1, so again, this looks like we're overparameterized


plot(RESP1.lmer,resid(.,scaled=TRUE)~fitted(.),abline=0,pch=16,xlab="Fitted values",ylab="Standardised residuals")
#the plot is funnel shaped, indicating that we're violating the assumption of homoskedasticity in the model
#let's plot this with color to see if we can discern any further patterns
#it's further apparent that the residuals vary more as we get up to higher value
plot(RESP1.lmer,resid(.,scaled=TRUE)~fitted(.),abline=0,pch=16,col=CONC$Sensor,xlab="Fitted values",ylab="Standardised Residuals")
# all of these sensors are showing clear heteroskedasticity, so we're going to need to transform the data

