RESP2.All.Summary<-summarySE(RESP2, measurevar = "Respiration", groupvars = c("Sensor","Method"))
RESP2.All.plot<-ggplot(RESP2.All.Summary,aes(x=Method,y=Respiration,colour=Sensor,group=Sensor))+geom_errorbar(aes(ymin=Respiration-se,ymax=Respiration+se),width=.2)+geom_line()+theme_bw()+geom_point(size=4)
RESP2.All.plot
