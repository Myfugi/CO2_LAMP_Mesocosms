#Get Summary Statistics, group by Hours and Run
RESP2.Run.Summary<-summarySE(RESP2, measurevar = "Respiration", groupvars = c("Hours","Run"))

#Visualize that data
RESP2.Run.plot<-ggplot(RESP2.Run.Summary,aes(x=Hours,y=Respiration,colour=Run,group=Run))+geom_errorbar(aes(ymin=Respiration-se,ymax=Respiration+se),width=.2)+geom_line()+theme_bw()+geom_point(size=4)
RESP2.Run.plot
#Again, looks as though it's approporiate to treat Run as a random effect

#run a linear mixed model treating sensor as random to try and rule out run as a significant effect: 
RESP2.transformed.lmer<-lmer(Respiration~Hours*Method*Sensor + (1|Run),data=RESP2)
RESP2.transformed.lmer.anova<-anova(RESP2.transformed.lmer)
RESP2.transformed.lmer.anova
check_model(RESP2.transformed.lmer)
#great model fit. a bit heteroskedastic still

#try with run and sensor both as random effects
RESP3.transformed.lmer<-lmer(Respiration~Hours*Method +(Sensor|Run),data=RESP2)
RESP3.transformed.lmer.anova<-anova(RESP3.transformed.lmer)
RESP3.transformed.lmer.anova
check_model(RESP3.transformed.lmer)
#better06815
#We do have some evidence that there are some interactions between sensor and method, 
#and between run and method, but the effects appear to be random, and we get the best model fit
#when we treat them as such. This model ended up having a singular fit though, so not ideal

#try with run and sensor both as random effects
RESP4.transformed.lmer<-lmer(Respiration~Hours*Method +(1|Run)+(1|Sensor),data=RESP2)
RESP4.transformed.lmer.anova<-anova(RESP4.transformed.lmer)
RESP4.transformed.lmer.anova
check_model(RESP4.transformed.lmer)
