#Linear Mixes Effects Model for CO2 concentration measured with CO2 Sensor Equipped
#mesocosms vs a traditional Gas Chromatograph. 

#Load Necessary Libraries and Packages
library(Rmisc)
library(ggplot2)
library(rstatix)
library(lme4)
library(lmerTest)
library(easystats)
library(tidyverse)
library(glmmTMB)

#load in data
CONC<-read.delim(file.choose())

#Check Structure of the data
str(CONC)
head(CONC)
CONC
#Need to set ID, Sensor, Run, Hours, and Method as "Factors" 

CONC<-CONC%>%convert_as_factor(ID,Sensor,Run, Hours,Method)

#check your work
str(CONC)


#Get Summary Statistics, group by Hours and Method
CONC.summary<-summarySE(CONC,measurevar="Concentration",groupvars=c("Hours","Method"))


#plot the data to visualize
CONC1.plot<-ggplot(CONC.summary,aes(x=Hours,y=Concentration,colour=Method,group=Method))+geom_errorbar(aes(ymin=Concentration-se,ymax=Concentration+se),width=.2)+geom_line()+theme_bw()+geom_point(size=4)
CONC1.plot

#as we can see from the SE overlap, it doesn't look like the sensor measurement and GC measurement are significant
#but we need to run a mixed model or repeat measure anova to confirm, but as there are data points missing
#from the sensor data, a linear mixed model is the better approach
#We want to look at the effect of sensor on the concentration, to see if there is an effect, and if there is an interaction

CONC.Sens.Summary<-summarySE(CONC, measurevar = "Concentration", groupvars = c("Hours","Sensor"))

#Visualize that data
CONC.sens.plot<-ggplot(CONC.Sens.Summary,aes(x=Hours,y=Concentration,colour=Sensor,group=Sensor))+geom_errorbar(aes(ymin=Concentration-se,ymax=Concentration+se),width=.2)+geom_line()+theme_bw()+geom_point(size=4)
CONC.sens.plot
#It doesn't look like the different sensors are obviously different from one another

CONC.All.Summary<-summarySE(CONC, measurevar = "Concentration", groupvars = c("Sensor","Method"))
CONC.All.plot<-ggplot(CONC.All.Summary,aes(x=Method,y=Concentration,colour=Sensor,group=Sensor))+geom_errorbar(aes(ymin=Concentration-se,ymax=Concentration+se),width=.2)+geom_line()+theme_bw()+geom_point(size=4)
CONC.All.plot
#Sensor 1 and sensor 2 don't look like they match the GC measurements as well as Sensor 4 does, This is likely due to Sensor 1 R2, where the sensor measurement
#diverges significantly after 12 hours probably because of a sensor malfunction, as the GC measurements look normal. And sensor 2 Run 2 when the sensor and GC
#measurements diverge significantly after 240 hours, for an unknown reading, as the sensor behaves normally for the beginning of the third run at which point we're 
#getting repeat measurements that aren't likely to be accurate. It may be appropriate to remove those data entirely, but first lets see how they are affecting
#the statistics


#Get Summary Statistics, group by Hours and Run
CONC.Run.Summary<-summarySE(CONC, measurevar = "Concentration", groupvars = c("Hours","Run"))

#Visualize that data
CONC.Run.plot<-ggplot(CONC.Run.Summary,aes(x=Hours,y=Concentration,colour=Run,group=Run))+geom_errorbar(aes(ymin=Concentration-se,ymax=Concentration+se),width=.2)+geom_line()+theme_bw()+geom_point(size=4)
CONC.Run.plot
# there's very little obvious effect of run on the concentration, so Run can remain being considered a random effect. 

#run a linear mixed model treating sensor as random to try and rule out run as a significant effect: 
CONC.lmer<-lmer(Concentration~Hours*Method*Run + (1|Sensor),data=CONC)
CONC.lmer.anova<-anova(CONC.lmer)
CONC.lmer.anova
#When we check the ANOVA, only time is signficant, so we can reasonably treat run as random, or 
#ignore run from the model entirely, but first let's treat it as a random effect and see how it affects the model
#run the linear mixed model: here we're treating Hours, Method and sensor as fixed effects, and run as random. 
CONC1.lmer<-lmer(Concentration~Hours*Method*Sensor + (1|Run), data=CONC)

#Check the Assumption of normality
CONC1.qqplot<-qqnorm(resid(CONC1.lmer))
CONC1.qqline<-qqline(resid(CONC1.lmer))
#Imperfect Normality, there are some pretty clear outliers here, however lme models are robust to
#violations of normality, so we're going to go ahead and still run anova 

#run an Anova on the linear mixed model wth a type II Wald test
CONC1.lmer.Anova<-Anova(CONC1.lmer)
CONC1.lmer.Anova
#Timestep and sensor are both significant effects, but method is not, however there is a significant interaction
#effect, so we may need to investigate that further, We're also going to do an anova using a type III ANOVA 
#using Satterthwaite's method
CONC1.lmer.anova<-anova(CONC1.lmer)
CONC1.lmer.anova
#The significant effects are the same so we need to determine whether sensor can be considered random or not. 
#Theoretically, there are an infinite number of sensors, so it should be reasonable to consider it a random effect, 
#but since we also have that significant effect, it's worth our time to determine how that effect is significant
#so that we can determine how random it actually is


plot(CONC1.lmer,resid(.,scaled=TRUE)~fitted(.),abline=0,pch=16,xlab="Fitted values",ylab="Standardised residuals")
#the plot is funnel shaped, indicating that we're violating the assumption of homoskedasticity in the model
#let's plot this with color to see if we can discern any further patterns, it's further apparent that the residuals vary more as we get up to higher value
plot(CONC1.lmer,resid(.,scaled=TRUE)~fitted(.),abline=0,pch=16,col=CONC$Sensor,xlab="Fitted values",ylab="Standardised Residuals")
# 2 of the three sensors are heteroskedastic, and the other appears homoskedastic, again, our problem children
#here are sensors 1 and 2, and as noted previously this is mostly due to Run 2 where we have some weird sensor
#behaviors

#Just to see what it looks like, let's treat both sensor and Run as random effects
CONC2.lmer<-lmer(Concentration~Hours*Method + (Sensor|Run),data=CONC,REML=FALSE)
anova(CONC2.lmer) 

#we get a singular fit when we run the anova with both sensor and run as random effects, which means we've likely 
#overfitted the model here, but let's just look at the residuals to see what we've got

plot(CONC2.lmer,resid(.,scaled=TRUE)~fitted(.),abline=0,pch=16,xlab="Fitted values",ylab="Standardised residuals")
#the plot is still funnel shaped, indicating that we're violating the assumption of homoskedasticity in the model
#lets look at it in color to confirm
plot(CONC2.lmer,resid(.,scaled=TRUE)~fitted(.),abline=0,pch=16,col=CONC$Sensor,xlab="Fitted values",ylab="Standardised Residuals")
#Again, the heteroskedasticity is still apparent, and again, it mostly appears to be occuring in the data
#for sensors 1 and 2

#Since Run is non significant, we're going to re-run the model with sensor as the only random effect and see if that fit is any better.
CONC3.lmer<-lmer(Concentration~Hours*Method + (1|Sensor),data=CONC,REML=FALSE)
anova(CONC3.lmer) 
#When we ignore run entirely, since it doesn't appear to have any effect at all, and treat sensor as random, 
#then we no longer get a singular effect and we have time as the only significant effect. As we established when
#checking the effect of run, we've already determined that it isn't significant so it's reasonable to ignore 
#run in the model, but let's still check the fit of the model: 
plot(CONC3.lmer,resid(.,scaled=TRUE)~fitted(.),abline=0,pch=16,xlab="Fitted values",ylab="Standardised residuals")
#this plot is identical to the previous residual plot, confirming that run is entirely not relevant, 
#but also indicating that there is still some violation of the homoskedasticity assumption
plot(CONC3.lmer,resid(.,scaled=TRUE)~fitted(.),abline=0,pch=16,col=CONC$Sensor,xlab="Fitted values",ylab="Standardised Residuals")
#again, we're having the same sources for the heteroskedasticity, it's sensors one and 2. 
#We can try to resolve this by removing the potentially problematic data, which is reasonable since we have 
#good evidence that the sensors were malfunctioning for at least part of the runs, but since the potential for 
#sensor malfunction is important when we are thinking about whether sensors are a good substitute for GCs, we
#can first see if a generalized mixed effects model is more effective, or if we can do some numeric tranformations
#(log transformations, etc.), to deal with the assumptions violations

#First I'm going to try a generalized mixed effects model: 
#We need to determine how the data is distributed, so we'll do some bootstrapping and see if it matches one of the common distributions
descdist(CONC$Concentration,discrete=FALSE,boot=500)
#both the real data and the bootstrap data fall perfectly within our beta distribution, so we now know how our data is distributed
#but first we need to scale the data, because a beta distribution has to fall between 0 and 1 values for GLMM Modeling

min_val<-min(CONC$Concentration,na.rm=TRUE)
max_val<-max(CONC$Concentration,na.rm=TRUE)
scaled_response<-(CONC$Concentration-min_val)/(max_val-min_val)
N<-length(na.omit(CONC$Concentration))
CONC$Scaled<-(scaled_response*(N-1)+0.5)/N
CONC.glmm<-glmmTMB(Scaled~Method*Sensor+(1|Run),family=beta_family(link="logit"),data=CONC)
check_model(CONC.glmm)
#Still not getting a good prediction fit, with Sensor as a fixed effect and run as a random 
#effect #let's look at the anoval for the glmm

Anova(CONC.glmm)

#this is still indicating that Sensor is signficant and that there is a significant 
#interaction effect between sensor and method, despite method being insignificant

#let's give a try with Sensor as a random effect and run removed from the model entirely'
CONC1.glmm<-glmmTMB(Scaled~Method + (1|Sensor),family=beta_family(link="logit"),data=CONC)
check_model(CONC1.glmm)
#well, model fit is worse when we treat sensor as random. It may be time to consider looking at 
#discarding the non-logical data. 

